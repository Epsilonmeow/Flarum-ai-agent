# ==========================================
# Flarum AI Agent - Environment Example
# Copy this file to .env and fill in real values.
# Never commit your .env file.
# ==========================================

# LLM API configuration (OpenAI-compatible)
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-3.5-turbo

# Optional system prompt / bot persona
SYSTEM_PROMPT=You are a warm and helpful AI assistant for a Flarum community.

# Flarum forum configuration
FLARUM_BASE_URL=https://your-forum.com
FLARUM_API_TOKEN=your-flarum-token-here

# Runtime ports and logging
LOG_LEVEL=INFO
WEBHOOK_PORT=8000
ADMIN_UI_PORT=8501

# Reply and memory behavior
REPLY_COOLDOWN_SECONDS=60
MEMORY_VALUE_THRESHOLD=0.3
MAX_MEMORY_CONTEXT=5
BOT_USERNAMES=AI Assistant,FlarumBot
BOT_USER_IDS=1,999

# Worldbook configuration
# Public releases do not include a real worldbook. Create this file yourself if needed.
WORLD_BOOK_FILE=worldbook.json

# Layered memory settings
MEMORY_BLOCK_SIZE=10
SUMMARY_TRIGGER_THRESHOLD=2
MAX_CONTEXT_MESSAGES=5
MAX_SUMMARIES_IN_PROMPT=3

# Affection system settings
DAILY_BONUS_POINTS=5
CONSECUTIVE_BONUS_POINTS=10
EMOTIONAL_SUPPORT_BONUS=5

# Embedding configuration
DEFAULT_EMBEDDING_MODEL=qwen
BGE_MODEL_PATH=
DASHSCOPE_API_KEY=

# Provider failover configuration (optional; keep JSON on one line)
PROVIDER_CONFIGS=
DEFAULT_PROVIDER_TYPE=openai